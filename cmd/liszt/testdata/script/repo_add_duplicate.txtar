# `liszt repo add` refuses an already-registered repo before cloning.
env NO_COLOR=1
env XDG_DATA_HOME=$WORK/data
env XDG_CACHE_HOME=$WORK/cache
mkdir $WORK/data/liszt
cp seed-repos.toml $WORK/data/liszt/repos.toml

exec liszt repo add https://github.com/obra/superpowers
stderr 'already added'
stderr 'repo update obra/superpowers'
! stderr 'ERROR'
! exists $WORK/cache/repos/obra/superpowers

-- seed-repos.toml --
[[repos]]
name = "obra/superpowers"
url = "https://github.com/obra/superpowers"
sha = "deadbeef"
